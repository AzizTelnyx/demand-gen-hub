      "usage": "Primary light background, default canvas",
      "logoColor": "black"
    },
    "black": {
      "hex": "#000000",
      "rgb": "0, 0, 0",
      "usage": "Primary text, high-contrast sections, dark mode backgrounds",
      "logoColor": "white"
    },
    "tan": {
      "hex": "#E6E3D3",
      "rgb": "230, 227, 211",
      "usage": "Secondary neutral backgrounds, subtle sections",
