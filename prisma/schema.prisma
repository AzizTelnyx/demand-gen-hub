generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id            String   @id @default(cuid())
  name          String
  platform      String
  platformId    String?
  status        String
  funnelStage   String?
  region        String?
  channel       String?
  budget        Float?
  spend         Float?
  impressions   Int?
  clicks        Int?
  conversions   Int?
  startDate     DateTime?
  endDate       DateTime?
  lastSyncedAt  DateTime?
  metadata      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AdCopy {
  id          String   @id @default(cuid())
  campaignId  String?
  name        String?
  headlines   String?
  descriptions String?
  status      String   @default("draft")
  feedback    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ABMList {
  id           String   @id @default(cuid())
  name         String
  description  String?
  criteria     String?
  accountCount Int      @default(0)
  status       String   @default("draft")
  accounts     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Activity {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  actor      String
  actorId    String?
  action     String
  entityType String
  entityId   String?
  entityName String?
  details    String?
}

model SyncState {
  id           String   @id @default(cuid())
  platform     String   @unique
  lastSyncedAt DateTime?
  status       String   @default("idle")
  error        String?
  metadata     String?
  updatedAt    DateTime @updatedAt
}

model BudgetPlan {
  id          String   @id @default(cuid())
  year        Int
  month       Int
  channel     String   // google_ads, stackadapt, linkedin, reddit
  region      String?  // AMER, EMEA, APAC, Global
  funnelStage String?  // TOFU, MOFU, BOFU, ABM
  planned     Float    // Planned budget
  actual      Float    @default(0) // Actual spend (updated from campaigns)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([year, month, channel, region, funnelStage])
}

model BudgetChange {
  id          String   @id @default(cuid())
  description String   // Natural language description
  fromChannel String?
  toChannel   String?
  fromRegion  String?
  toRegion    String?
  amount      Float
  reason      String?
  status      String   @default("proposed") // proposed, approved, applied
  appliedAt   DateTime?
  createdAt   DateTime @default(now())
}
